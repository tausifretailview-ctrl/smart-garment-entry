# Copy to .env before `npm run build` (values are baked into the Android app at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Install page — edge functions serve signed URLs from private bucket "app-downloads"
# VITE_ANDROID_APK_URL=https://lkbbrqcsbhqjvsxiorvp.supabase.co/functions/v1/download-apk
# VITE_WINDOWS_SETUP_URL=https://lkbbrqcsbhqjvsxiorvp.supabase.co/functions/v1/download-windows
# VITE_WINDOWS_PORTABLE_URL=https://lkbbrqcsbhqjvsxiorvp.supabase.co/functions/v1/download-windows?file=EzzyERP-Portable-1.1.0.exe
# Leave blank to use the defaults above (derived from your Supabase project).
VITE_ANDROID_APK_URL=
VITE_WINDOWS_SETUP_URL=
VITE_WINDOWS_PORTABLE_URL=
