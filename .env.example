# Copy to .env before `npm run build` (values are baked into the Android app at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Install page — hosted installers (set in Vercel for production; optional locally)
# Supabase Storage public URL example:
# VITE_ANDROID_APK_URL=https://your-project.supabase.co/storage/v1/object/public/app-downloads/EzzyERP-1.1.0.apk
VITE_ANDROID_APK_URL=
VITE_WINDOWS_SETUP_URL=
VITE_WINDOWS_PORTABLE_URL=
