# Copy to .env.test and export before integration tests — NEVER use production.
# Local Supabase: run `supabase status` for URL and service_role key.

SUPABASE_TEST_URL=http://127.0.0.1:54321
SUPABASE_TEST_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: reuse an existing org instead of creating one per run
# SUPABASE_TEST_ORG_ID=
