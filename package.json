{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:money": "vitest run test/money src/utils/customerBalanceCore.shumama.test.ts src/utils/saleInvoiceStatus.test.ts",
    "test:integration": "vitest run test/integration",
    "test:seed": "vitest run test/scripts/seed-staging.test.ts",
    "test:verify-staging": "vitest run test/scripts/verify-staging-schema.test.ts",
    "check:cn-guard": "node scripts/check-cn-adjust-literals.mjs",
    "preview": "vite preview",
    "build:android": "npm run build && npx cap sync android",
    "build:apk:debug": "npm run build:android && cd android && gradlew.bat assembleDebug",
    "build:apk:release": "npm run build:android && cd android && gradlew.bat assembleRelease",
    "publish:apk": "npm run build:apk:debug && node scripts/copy-apk-to-public.mjs",
    "android:open": "npx cap open android",
    "android:run": "npm run build:android && npx cap run android",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:8080 && electron .\"",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.ezzyerp.desktop",
    "productName": "EzzyERP",
    "copyright": "Copyright © 2026 EzzyERP",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "!node_modules/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/at-least-node/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/argparse/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "tausifretailview-ctrl",
        "repo": "smart-garment-entry"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "EzzyERP-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EzzyERP",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "EzzyERP-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/network": "^7.0.4",
    "@capacitor/splash-screen": "^7.0.5",
